[
  {
    "processor_name": "rounded_corner",
    "border_radius": "{{vh(2)}}"
  },
  {
    "processor_name": "shadow",
    "shadow_radius": "{{vh(1)}}",
    "shadow_color": "black"
  },
  {
    "processor_name": "blur",
    "blur_radius": "{{vh(3)}}",
    "buffer_path": [
      "{{file_path}}"
    ]
  },
  {
    "processor_name": "resize",
    "scale": 2
  },
  {
    "processor_name": "alignment",
    "weights": "[100,-100]",
    "select": "[2,4]"
  },
  {
    "processor_name": "crop",
    "width": "{{vw(110)}}",
    "height": "{{vh(110)}}",
    "offset": "[0, 0]"
  }
]
